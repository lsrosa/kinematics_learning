<?xml version="1.0"?>

<!-- Make the namespace of the robot-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="r2_arm">
    <!--Define constants-->
    
    <xacro:property name="M_PI" value="3.14159"/>
    
    <!-- Constants for the robotic arm (masses in kg, lengths in m) -->

    <xacro:property name="max_effort" value="100" />
    <xacro:property name="max_velocity" value="${M_PI/4}" />

    <xacro:property name="damping_1" value="0.02" />
    <xacro:property name="damping_2" value="0.02" />

    <!-- base_link -->
    <xacro:property name="length_0" value="0.005" /> 
    <xacro:property name="radius_0" value="0.015" /> 
    <xacro:property name="mass_0" value="0.200" />

    <!-- joint_f1 fixed -->

    <!-- link_1 -->
    <xacro:property name="length_1" value="0.012" />
    <xacro:property name="radius_1" value="0.005" />
    <xacro:property name="mass_1" value="0.100" />

    <!-- joint_f2 fixed -->

    <!-- link_j1 -->
    <xacro:property name="length_j1" value="0.005" /> 
    <xacro:property name="radius_j1" value="0.003" />
    <xacro:property name="mass_j1" value="0.020" />

    <!-- revolute joint link_j1 - link_2 -->

    <!-- link_2 -->
    <xacro:property name="length_2" value="0.025" />
    <xacro:property name="radius_2" value="0.002" />
    <xacro:property name="mass_2" value="0.100" />

    <!-- joint_f3 fixed -->

    <!-- link_j2 -->
    <xacro:property name="length_j2" value="0.005" /> 
    <xacro:property name="radius_j2" value="0.003" />
    <xacro:property name="mass_j2" value="0.020" />

    <!-- revolute joint link_j2 - link_3 -->

    <!-- link_3 -->
    <xacro:property name="length_3" value="0.025" />
    <xacro:property name="radius_3" value="0.002" />
    <xacro:property name="mass_3" value="0.100" />

    <!-- joint_f4 fixed link_3 - link_ee -->
    
    <!-- link_ee -->
    <xacro:property name="length_ee" value="0.005" />
    <xacro:property name="radius_ee" value="0.003" />
    <xacro:property name="mass_ee" value="0.100" />


    <!--Define colors-->
    <material name="Black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>
    <material name="Red">
        <color rgba="0.8 0.0 0.0 1.0"/>
    </material>
    <material name="Blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
    </material>
    <material name="LightBlue">
        <color rgba="0.589 0.793 1.0 1.0"/>
    </material>
    <material name="Grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
    </material>
    <material name="White">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>

    <!-- macros for inertia -->

    <!-- ref: https://en.wikipedia.org/wiki/List_of_moments_of_inertia#List_of_3D_inertia_tensors -->

    <xacro:macro name="cylinder_inertial_block" params="mass length radius">
      <inertial>
        <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia
            ixx="${mass / 12.0 * (3*radius*radius+length*length)}" ixy="0.0" ixz="0.0"
            iyy="${mass / 12.0 * (3*radius*radius+length*length)}" iyz="0.0"
            izz="${mass / 2.0 * (radius*radius)}" />
      </inertial>
    </xacro:macro>
    
    <xacro:macro name="box_inertial_block" params="mass x y z">
      <inertial>
        <origin xyz="0 0 ${z/2}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia
            ixx="${mass / 12.0 * (y*y+z*z)}" ixy="0.0" ixz="0.0"
            iyy="${mass / 12.0 * (x*x+z*z)}" iyz="0.0"
            izz="${mass / 12.0 * (x*x+y*y)}" />
      </inertial>
    </xacro:macro>

    <!-- macros for transmission -->
    <xacro:macro name="transmission_block" params="joint_name">
	  <transmission name="tran1">
	    <type>transmission_interface/SimpleTransmission</type>
	    <joint name="${joint_name}">
          <!-- Position/Velocity/Effort|JointInterface -->
	      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
	    </joint>
	    <actuator name="motor_${joint_name}">
	      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
	      <mechanicalReduction>1</mechanicalReduction>
	    </actuator>
	  </transmission>
    </xacro:macro>

    <!--Define Gazebo colors-->
    <xacro:macro name="gazebo_grey_link_color_block" params="link_name">
    <gazebo reference="${link_name}">
    <visual>
      <material>
        <ambient>0.5 0.5 0.5 1.0</ambient>
        <diffuse>0.56666695 0.56666695 0.56666695 1.0</diffuse>
        <specular>0.6000003 0.6000003 0.6000003 1.0</specular>
      </material>
    </visual>
    </gazebo>
    </xacro:macro>

    <xacro:macro name="gazebo_blue_link_color_block" params="link_name">
    <gazebo reference="${link_name}">
    <visual>
      <material>
	<ambient>0.589 0.793 1.0 1.0</ambient>
	<diffuse>0.56666695 0.56666695 0.56666695 1.0</diffuse>
	<specular>0.6000003 0.6000003 0.6000003 1.0</specular>
      </material>
    </visual>
    </gazebo>
    </xacro:macro>

    <xacro:macro name="gazebo_orange_link_color_block" params="link_name">
    <gazebo reference="${link_name}">
    <visual>
      <material>
	    <ambient>1.0 0.4 0.0 1.0</ambient>
	    <diffuse>0.56666695 0.56666695 0.56666695 1.0</diffuse>
	    <specular>0.6000003 0.6000003 0.6000003 1.0</specular>
      </material>
    </visual>
    </gazebo>
    </xacro:macro>

    <xacro:macro name="gazebo_red_link_color_block" params="link_name">
    <gazebo reference="${link_name}">
    <visual>
      <material>
	    <ambient>1.0 0.0 0.0 1.0</ambient>
	    <diffuse>0.56666695 0.56666695 0.56666695 1.0</diffuse>
	    <specular>0.6000003 0.6000003 0.6000003 1.0</specular>
      </material>
    </visual>
    </gazebo>
    </xacro:macro>
  
    <xacro:macro name="gazebo_self_collision" params="link_name">
    <gazebo reference="${link_name}">
      <selfCollide>true</selfCollide>
    </gazebo>
    </xacro:macro>

    <!--=============================================================================-->
    
    <link name="world"/>

    <!-- joint world - base_link -->
    <joint name="world_joint" type="fixed">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/> 
        <parent link="world"/>
        <child link="base_link"/>
    </joint>
    
    <!-- base_link -->
    <link name="base_link">
        <xacro:cylinder_inertial_block mass="${mass_0}" length="${length_0}" radius="${radius_0}"/>
        <visual>
            <origin xyz="0.0 0.0 ${length_0/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_0}" length="${length_0}"/>
            </geometry>
            <material name="LightBlue"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${length_0/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_0}" length="${length_0}"/>
            </geometry>>
        </collision>
    </link>
    <xacro:gazebo_orange_link_color_block link_name="base_link"/>

    <!-- fixed joint base_link - link_1 -->
    <joint name="joint_f1" type="fixed">
        <origin xyz="0.0 0.0 ${length_0}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="link_1"/>
    </joint>
    <gazebo reference="joint_f1">
        <disableFixedJointLumping>true</disableFixedJointLumping> 
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>

    <!-- link_1 -->
    <link name="link_1">
        <xacro:cylinder_inertial_block mass="${mass_1}" length="${length_1}" radius="${radius_1}"/>
        <visual>
            <origin xyz="0.0 0.0 ${length_1/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_1}" length="${length_1}"/>
            </geometry>
            <material name="Grey"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${length_1/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_1}" length="${length_1}"/>
            </geometry>>
        </collision>
    </link>
    <xacro:gazebo_grey_link_color_block link_name="link_1"/>

    <!-- revolute joint link_1 - link_j1 -->
    <joint name="joint_1" type="revolute">
        <origin xyz="0.0 0.0 ${length_1}" rpy="0.0 0.0 0.0"/>
        <parent link="link_1"/>
        <child link="link_j1"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="${damping_1}" friction="0.001" />
        <limit lower="${-100*M_PI}" upper="${100*M_PI}" effort="${max_effort}" velocity="${max_velocity}"/>
    </joint>

    <!-- link link_j1 -->
    <link name="link_j1">
        <xacro:cylinder_inertial_block mass="${mass_j1}" length="${length_j1}" radius="${radius_j1}"/>
        <visual>
            <origin xyz="0.0 0.0 ${length_j1/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_j1}" length="${length_j1}"/>
            </geometry>
            <material name="LightBlue"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${length_j1/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_j1}" length="${length_j1}"/>
            </geometry>
        </collision>
    </link>
    <xacro:gazebo_blue_link_color_block link_name="link_j1"/>


    <!-- fixed joint link_j1 - link_2 -->
    <joint name="joint_f2" type="fixed">
        <origin xyz="${radius_j1} 0.0 ${length_j1/2.0}" rpy="0.0 ${M_PI/2} 0.0"/>
        <parent link="link_j1"/>
        <child link="link_2"/>
    </joint>
    <gazebo reference="joint_f2">
        <disableFixedJointLumping>true</disableFixedJointLumping> 
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>

    
    
    <!--link_2-->
    <link name="link_2">
        <xacro:cylinder_inertial_block mass="${mass_2}" length="${length_2}" radius="${radius_2}"/>
        <visual>
            <origin xyz="0.0 0.0 ${length_2/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_2}" length="${length_2}"/>
            </geometry>
            <material name="Grey"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${length_2/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_2}" length="${length_2}"/>
            </geometry>>
        </collision>
    </link>
    <xacro:gazebo_grey_link_color_block link_name="link_2"/>


    <!-- revolute joint link_2 - link_j2 -->
    <joint name="joint_2" type="revolute">
        <origin xyz="${length_j2/2.0} 0.0 ${length_2+radius_j2}" rpy="0.0 ${-M_PI/2} 0.0"/>
        <parent link="link_2"/>
        <child link="link_j2"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="${damping_2}" friction="0.001"/>
        <limit lower="${-M_PI}" upper="${M_PI}" effort="${max_effort}" velocity="${max_velocity}"/>
    </joint>

    <!-- link link_j2 -->
    <link name="link_j2">
        <xacro:cylinder_inertial_block mass="${mass_j2}" length="${length_j2}" radius="${radius_j2}"/>
        <visual>
            <origin xyz="0.0 0.0 ${length_j2/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_j2}" length="${length_j2}"/>
            </geometry>
            <material name="LightBlue"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${length_j2/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_j2}" length="${length_j2}"/>
            </geometry>
        </collision>
    </link>
    <xacro:gazebo_blue_link_color_block link_name="link_j2"/>


    <!-- fixed joint link_j2 - link_3 -->
    <joint name="joint_f3" type="fixed">
        <origin xyz="${radius_j2} 0.0 ${length_j2/2.0}" rpy="0.0 ${M_PI/2} 0.0"/>
        <parent link="link_j2"/>
        <child link="link_3"/>
    </joint>
    <gazebo reference="joint_f3">
        <disableFixedJointLumping>true</disableFixedJointLumping> 
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>


    <!--link_3-->
    <link name="link_3">
        <xacro:cylinder_inertial_block mass="${mass_3}" length="${length_3}" radius="${radius_3}"/>
        <visual>
            <origin xyz="0.0 0.0 ${length_3/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_3}" length="${length_3}"/>
            </geometry>
            <material name="Grey"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${length_3/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_3}" length="${length_3}"/>
            </geometry>>
        </collision>
    </link>    
    <xacro:gazebo_grey_link_color_block link_name="link_3"/>
 


    <!-- fixed joint link_3 - link_ee -->
    <joint name="joint_f4" type="fixed">
        <origin xyz="${-radius_3} 0.0 ${length_3+radius_ee}" rpy="0.0 ${M_PI/2} 0.0"/>
        <parent link="link_3"/>
        <child link="link_ee"/>
    </joint>
    <gazebo reference="joint_f4">
        <disableFixedJointLumping>true</disableFixedJointLumping> 
        <preserveFixedJoint>true</preserveFixedJoint>
    </gazebo>
    
    
    <!--link_ee-->
    <link name="link_ee">
        <xacro:cylinder_inertial_block mass="${mass_ee}" length="${length_ee}" radius="${radius_ee}"/>
        <visual>
            <origin xyz="0.0 0.0 ${length_ee/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_ee}" length="${length_ee}"/>
            </geometry>
            <material name="Red"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 ${length_ee/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${radius_ee}" length="${length_ee}"/>
            </geometry>>
        </collision>
    </link>    
    <xacro:gazebo_red_link_color_block link_name="link_ee"/>


<!-- self collision -->


     <xacro:gazebo_self_collision link_name="base_link"/>
     <xacro:gazebo_self_collision link_name="link_1"/>
     <xacro:gazebo_self_collision link_name="link_2"/>
     <xacro:gazebo_self_collision link_name="link_3"/>
     <xacro:gazebo_self_collision link_name="link_j1"/>
     <xacro:gazebo_self_collision link_name="link_j2"/>
     <xacro:gazebo_self_collision link_name="link_ee"/>
 
<!-- ========================================================================= -->


    <!-- Transmissions for ros control -->
    <xacro:transmission_block joint_name="joint_1"/>
    <xacro:transmission_block joint_name="joint_2"/>
    
    <!-- ros_control plugin -->
    <gazebo>
        <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
        <robotNamespace>/r2_arm</robotNamespace>
        </plugin>
    </gazebo>

</robot>
